﻿---
// Layout.astro - Main Layout Component
// Professional layout with ambient background and smooth animations
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  noPadding?: boolean;
}

const { title, description = "High-end architecture studio portfolio", noPadding = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Preconnect to Google Fonts for better performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Google Fonts - Inter + Space Grotesk for modern look -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <title>{title}</title>
    
    <style is:global>
      /* Base font settings */
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        background: #0A0A0E;
        color: #FAFAFA;
        line-height: 1.6;
        overflow-x: hidden;
      }
      
      /* Custom scrollbar */
      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }
      
      ::-webkit-scrollbar-track {
        background: #1A1A1E;
      }
      
      ::-webkit-scrollbar-thumb {
        background: #3A3A40;
        border-radius: 4px;
      }
      
      ::-webkit-scrollbar-thumb:hover {
        background: #A078FF;
      }
      
      /* Smooth scrolling */
      html {
        scroll-behavior: smooth;
      }
      
      /* Selection color */
      ::selection {
        background: rgba(160, 120, 255, 0.3);
        color: #FFFFFF;
      }
      
      /* Focus visible for accessibility */
      :focus-visible {
        outline: 2px solid #A078FF;
        outline-offset: 2px;
        border-radius: 4px;
      }
      
      /* Typography defaults */
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Space Grotesk', 'Inter', sans-serif;
        font-weight: 600;
        line-height: 1.2;
        letter-spacing: -0.02em;
      }
      
      a {
        text-decoration: none;
        color: inherit;
      }
      
      button {
        background: none;
        border: none;
        cursor: pointer;
      }
      
      /* Utility classes */
      .container {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 2rem;
      }
      
      @media (max-width: 768px) {
        .container {
          padding: 0 1.25rem;
        }
      }
      
      /* Animation keyframes */
      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      
      @keyframes fadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }
      
      @keyframes scaleIn {
        from {
          opacity: 0;
          transform: scale(0.95);
        }
        to {
          opacity: 1;
          transform: scale(1);
        }
      }
      
      @keyframes float {
        0%, 100% {
          transform: translateY(0px) rotate(0deg);
        }
        50% {
          transform: translateY(-20px) rotate(2deg);
        }
      }
      
      @keyframes gridPulse {
        0%, 100% {
          opacity: 0.3;
        }
        50% {
          opacity: 0.6;
        }
      }
      
      /* Animation classes */
      .reveal {
        animation: fadeInUp 0.8s cubic-bezier(0.2, 0.9, 0.4, 1.1) forwards;
      }
      
      .reveal-delay-1 {
        animation: fadeInUp 0.8s cubic-bezier(0.2, 0.9, 0.4, 1.1) 0.1s forwards;
        opacity: 0;
      }
      
      .reveal-delay-2 {
        animation: fadeInUp 0.8s cubic-bezier(0.2, 0.9, 0.4, 1.1) 0.2s forwards;
        opacity: 0;
      }
      
      .reveal-delay-3 {
        animation: fadeInUp 0.8s cubic-bezier(0.2, 0.9, 0.4, 1.1) 0.3s forwards;
        opacity: 0;
      }
      
      .reveal-delay-4 {
        animation: fadeInUp 0.8s cubic-bezier(0.2, 0.9, 0.4, 1.1) 0.4s forwards;
        opacity: 0;
      }
      
      .reveal-scale {
        animation: scaleIn 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) forwards;
      }
      
      /* Ambient background animations */
      .orb-float {
        animation: float 12s ease-in-out infinite;
      }
      
      .grid-fade {
        animation: gridPulse 8s ease-in-out infinite;
      }
      
      /* Reduce motion preference */
      @media (prefers-reduced-motion: reduce) {
        .reveal,
        .reveal-delay-1,
        .reveal-delay-2,
        .reveal-delay-3,
        .reveal-delay-4,
        .reveal-scale,
        .orb-float,
        .grid-fade {
          animation: none !important;
          opacity: 1 !important;
          transform: none !important;
        }
        
        html {
          scroll-behavior: auto !important;
        }
      }
      
      /* Main content spacing */
      .main-content {
        min-height: 100vh;
        position: relative;
        z-index: 1;
      }
      
      /* No padding option for full-width pages */
      .main-content.no-padding {
        padding: 0;
      }
    </style>
  </head>
  <body>
    <!-- Ambient animated background -->
    <div aria-hidden="true" class="ambient-bg">
      <!-- Radial gradient base -->
      <div class="bg-gradient"></div>
      
      <!-- Grid pattern with fade -->
      <div class="grid-pattern"></div>
      
      <!-- Floating orbs -->
      <div class="orb orb-1 orb-float"></div>
      <div class="orb orb-2 orb-float" style="animation-delay: -2.2s;"></div>
      <div class="orb orb-3 orb-float" style="animation-delay: -4.6s;"></div>
      
      <!-- Additional floating particles -->
      <div class="particle particle-1"></div>
      <div class="particle particle-2"></div>
      <div class="particle particle-3"></div>
    </div>

    <Header />
    
    <main class="main-content" class:list={{ 'no-padding': noPadding }}>
      <slot />
    </main>
    
    <Footer />

    <!-- Cursor glow effect -->
    <script>
      (function() {
        // Check if mouse is available and motion is not reduced
        const isFinePointer = matchMedia('(pointer: fine)').matches;
        const prefersReducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
        
        if (!isFinePointer || prefersReducedMotion) return;
        
        let mouseX = 0;
        let mouseY = 0;
        let rafId = null;
        
        // Create cursor glow element
        const cursorGlow = document.createElement('div');
        cursorGlow.style.cssText = `
          position: fixed;
          width: 400px;
          height: 400px;
          border-radius: 50%;
          background: radial-gradient(circle, rgba(160, 120, 255, 0.08) 0%, rgba(160, 120, 255, 0.03) 40%, transparent 70%);
          pointer-events: none;
          transform: translate(-50%, -50%);
          z-index: 9997;
          transition: opacity 0.3s ease;
          opacity: 0;
        `;
        document.body.appendChild(cursorGlow);
        
        // Show cursor glow when mouse moves
        let timeoutId: ReturnType<typeof setTimeout> | undefined;
        
        window.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          
          if (cursorGlow.style.opacity === '0') {
            cursorGlow.style.opacity = '1';
          }
          
          // Clear previous timeout
          if (timeoutId) clearTimeout(timeoutId);
          
          // Hide after 2 seconds of no movement
          timeoutId = setTimeout(() => {
            cursorGlow.style.opacity = '0';
          }, 2000);
          
          if (!rafId) {
            rafId = requestAnimationFrame(() => {
              cursorGlow.style.left = mouseX + 'px';
              cursorGlow.style.top = mouseY + 'px';
              rafId = null;
            });
          }
        });
        
        // Hide cursor glow when leaving window
        window.addEventListener('mouseleave', () => {
          cursorGlow.style.opacity = '0';
        });
      })();
    </script>
    
    <!-- Add hover-glow to elements that should have cursor glow -->
    <script>
      // Add hover-glow class to cards and buttons
      document.addEventListener('DOMContentLoaded', () => {
        const elementsToGlow = document.querySelectorAll('.card, .btn, .project-card, .journal-card, a');
        elementsToGlow.forEach(el => {
          if (!el.classList.contains('no-glow')) {
            el.classList.add('hover-glow');
          }
        });
      });
    </script>
  </body>
</html>

<style is:global>
  /* ============================================
     AMBIENT BACKGROUND STYLES
     ============================================ */
  
  .ambient-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  
  /* Gradient base */
  .bg-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(1200px circle at 20% -10%, rgba(160, 120, 255, 0.15), transparent 55%),
                radial-gradient(900px circle at 90% 10%, rgba(120, 255, 210, 0.12), transparent 52%),
                linear-gradient(180deg, #0A0A0E 0%, #0D0D12 100%);
  }
  
  /* Grid pattern */
  .grid-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.4;
    background-image: 
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse at 50% 30%, rgba(0, 0, 0, 1), rgba(0, 0, 0, 0) 70%);
    -webkit-mask-image: radial-gradient(ellipse at 50% 30%, rgba(0, 0, 0, 1), rgba(0, 0, 0, 0) 70%);
  }
  
  /* Floating orbs */
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
  }
  
  .orb-1 {
    top: -100px;
    left: -100px;
    width: 420px;
    height: 420px;
    background: radial-gradient(circle at 30% 30%, rgba(160, 120, 255, 0.5), rgba(160, 120, 255, 0.1) 55%, transparent 70%);
  }
  
  .orb-2 {
    top: 100px;
    right: -100px;
    width: 520px;
    height: 520px;
    background: radial-gradient(circle at 30% 30%, rgba(120, 255, 210, 0.4), rgba(120, 255, 210, 0.08) 55%, transparent 70%);
  }
  
  .orb-3 {
    bottom: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 560px;
    height: 560px;
    background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.04) 55%, transparent 70%);
  }
  
  /* Floating particles */
  .particle {
    position: absolute;
    width: 2px;
    height: 2px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    opacity: 0;
  }
  
  .particle-1 {
    top: 20%;
    left: 15%;
    animation: floatParticle 15s ease-in-out infinite;
    width: 3px;
    height: 3px;
    background: rgba(160, 120, 255, 0.4);
  }
  
  .particle-2 {
    top: 60%;
    right: 20%;
    animation: floatParticle 18s ease-in-out infinite 2s;
    width: 2px;
    height: 2px;
    background: rgba(120, 255, 210, 0.4);
  }
  
  .particle-3 {
    bottom: 30%;
    left: 30%;
    animation: floatParticle 12s ease-in-out infinite 4s;
    width: 4px;
    height: 4px;
    background: rgba(255, 255, 255, 0.3);
  }
  
  @keyframes floatParticle {
    0%, 100% {
      opacity: 0;
      transform: translateY(0px) translateX(0px);
    }
    25% {
      opacity: 0.5;
    }
    50% {
      opacity: 0.2;
      transform: translateY(-30px) translateX(20px);
    }
    75% {
      opacity: 0.6;
      transform: translateY(-60px) translateX(-10px);
    }
  }
  
  /* Hover glow effect for interactive elements */
  .hover-glow {
    position: relative;
    transition: all 0.3s ease;
  }
  
  /* Responsive adjustments */
  @media (max-width: 768px) {
    .orb-1,
    .orb-2,
    .orb-3 {
      transform: scale(0.7);
    }
    
    .grid-pattern {
      background-size: 32px 32px;
    }
  }
</style>