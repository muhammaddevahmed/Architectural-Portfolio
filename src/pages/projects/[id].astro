  }
  
  .related-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: #FFFFFF;
    margin-bottom: 0.25rem;
    transition: color 0.2s ease;
  }
  
  .related-card:hover .related-title {
    color: #A078FF;
  }
  
  .related-category {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
  }
  
  /* ===== Navigation ===== */
  .nav-section {
    padding: 4rem 0;
  }
  
  .nav-buttons {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 50px;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  
  .nav-link:hover {
    background: rgba(160, 120, 255, 0.1);
    border-color: rgba(160, 120, 255, 0.3);
    color: #A078FF;
  }
  
  .nav-link.back:hover {
    transform: translateX(-4px);
  }
  
  .nav-link.next:hover {
    transform: translateX(4px);
  }
  
  /* ===== Lightbox ===== */
  .lightbox {
    position: fixed;
    inset: 0;
