---
// Journal.astro - Professional Journal Layout
// Clean, sophisticated blog index with premium typography
// Converted to Tailwind CSS only
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('journal');

// Sort posts by date (newest first)
const sortedPosts = posts.sort((a: any, b: any) => {
  return b.data.date.valueOf() - a.data.date.valueOf();
});
---

<Layout title="Journal | STUDIO" description="Insights, stories, and thoughts from our studio on architecture, design, and creativity">
  <section class="journal-page">
    <div class="container">
      
      <!-- Hero Section -->
      <div class="journal-hero">
        <div class="hero-overline">Perspectives</div>
        <h1 class="hero-title">Journal</h1>
        <div class="hero-divider"></div>
        <p class="hero-description">
          Exploring the intersection of architecture, design, and human experience — 
          thoughts, stories, and ideas from our studio.
        </p>
      </div>

      <!-- Posts List - Minimal & Professional -->
      <div class="posts-list">
        {sortedPosts.map((post: any, index: number) => (
          <article class="post-entry" style={`--post-index: ${index}`}>
            <a href={`/journal/${post.id}`} class="post-link">
              <div class="post-index">{(index + 1).toString().padStart(2, '0')}</div>
              <div class="post-details">
                <div class="post-header">
                  <time class="post-date">
                    {post.data.date.toLocaleDateString('en-US', { 
                      year: 'numeric', 
                      month: 'long', 
                      day: 'numeric' 
                    })}
                  </time>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="post-category">{post.data.tags[0]}</div>
                  )}
                </div>
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-excerpt">{post.data.description}</p>
                <div class="post-meta">
                  {post.data.readTime && (
                    <span class="read-time">{post.data.readTime} min read</span>
                  )}
                  {post.data.author && (
                    <>
                      <span class="meta-separator">—</span>
                      <span class="post-author">By {post.data.author}</span>
                    </>
                  )}
                </div>
              </div>
              {post.data.heroImage && (
                <div class="post-thumbnail">
                  <img 
                    src={post.data.heroImage} 
                    alt={post.data.title}
                    loading={index < 3 ? "eager" : "lazy"}
                  />
                </div>
              )}
            </a>
          </article>
        ))}
      </div>

      {/* No Posts Message */}
      {sortedPosts.length === 0 && (
        <div class="empty-state">
          <div class="empty-icon">📝</div>
          <h3 class="empty-title">No posts yet</h3>
          <p class="empty-description">
            Check back soon for insights, stories, and updates from our studio.
          </p>
        </div>
      )}
      
    </div>
  </section>
</Layout>

<style is:global>
  /* ============================================
     ONLY ANIMATIONS & CUSTOM GRID - Tailwind cannot do these
     ============================================ */
  
  .journal-page {
    padding: 6rem 0 8rem;
    position: relative;
    background: #0A0A0E;
  }
  
  @media (max-width: 768px) {
    .journal-page {
      padding: 4rem 0 6rem;
    }
  }
  
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }
  }
  
  /* Hero Section */
  .journal-hero {
    margin-bottom: 5rem;
    text-align: center;
  }
  
  .hero-overline {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #A078FF;
    margin-bottom: 1rem;
  }
  
  .hero-title {
    font-size: 4rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: #FFFFFF;
    margin-bottom: 1.5rem;
  }
  
  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.5rem;
    }
  }
  
  .hero-divider {
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, #A078FF, #78FFD2);
    margin: 0 auto 1.5rem;
  }
  
  .hero-description {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.55);
    max-width: 550px;
    margin: 0 auto;
    line-height: 1.6;
  }
  
  /* Posts List - Custom Grid Layout */
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  
  .post-entry {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    transition: all 0.3s ease;
  }
  
  .post-entry:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  
  .post-link {
    display: grid;
    grid-template-columns: 60px 1fr 100px;
    gap: 2rem;
    padding: 2rem 0;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  
  @media (max-width: 900px) {
    .post-link {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding: 1.5rem 0;
    }
  }
  
  .post-entry:hover {
    background: rgba(255, 255, 255, 0.01);
  }
  
  .post-entry:hover .post-title {
    color: #A078FF;
  }
  
  .post-index {
    font-family: 'Space Grotesk', monospace;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.05em;
  }
  
  @media (max-width: 900px) {
    .post-index {
      display: none;
    }
  }
  
  .post-details {
    flex: 1;
  }
  
  .post-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  
  .post-date {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.4);
  }
  
  .post-category {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    background: rgba(160, 120, 255, 0.1);
    border: 1px solid rgba(160, 120, 255, 0.2);
    border-radius: 50px;
    color: #A078FF;
    letter-spacing: 0.02em;
  }
  
  .post-title {
    font-size: 1.75rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: #FFFFFF;
    margin-bottom: 0.75rem;
    transition: color 0.2s ease;
  }
  
  @media (max-width: 768px) {
    .post-title {
      font-size: 1.35rem;
    }
  }
  
  .post-excerpt {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.5;
    margin-bottom: 0.75rem;
    max-width: 85%;
  }
  
  @media (max-width: 900px) {
    .post-excerpt {
      max-width: 100%;
    }
  }
  
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
  }
  
  .read-time {
    letter-spacing: 0.02em;
  }
  
  .meta-separator {
    color: rgba(255, 255, 255, 0.2);
  }
  
  .post-author {
    letter-spacing: 0.02em;
  }
  
  .post-thumbnail {
    width: 100px;
    height: 100px;
    border-radius: 0.5rem;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.02);
  }
  
  @media (max-width: 900px) {
    .post-thumbnail {
      width: 80px;
      height: 80px;
      margin-top: 0.5rem;
    }
  }
  
  .post-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  
  .post-entry:hover .post-thumbnail img {
    transform: scale(1.05);
  }
  
  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 4rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 1rem;
  }
  
  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.5;
  }
  
  .empty-title {
    font-size: 1.25rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: rgba(255, 255, 255, 0.8);
  }
  
  .empty-description {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.4);
  }
  
  /* Animations */
  .post-entry {
    opacity: 0;
    animation: fadeInUp 0.5s cubic-bezier(0.2, 0.9, 0.4, 1.1) forwards;
    animation-delay: calc(var(--post-index, 0) * 0.05s);
  }
  
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
    from {
      opacity: 0;
      transform: translateY(20px);
    }
  }
  
  /* Reduce Motion Preference */
  @media (prefers-reduced-motion: reduce) {
    .post-entry {
      animation: none !important;
      opacity: 1 !important;
    }
    
    .post-entry:hover {
      transform: none !important;
    }
  }
  
  /* Responsive Adjustments */
  @media (max-width: 480px) {
    .post-title {
      font-size: 1.2rem;
    }
    
    .post-excerpt {
      font-size: 0.85rem;
    }
    
    .post-header {
      gap: 0.75rem;
    }
  }
</style>