---
// [id].astro - Journal Detail Page
// Clean blog post layout with TOC, share buttons, and author section
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('journal');
  return posts.map((post: any) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Format date
const formattedDate = post.data.date.toLocaleDateString('en-US', { 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});

// Estimate read time (assuming 200 words per minute)
const readTime = post.data.readTime || Math.ceil((post.body?.length || 0) / 200 / 60) || 5;

// Get headings for table of contents (h2 and h3)
const tocHeadings = headings?.filter(h => h.depth === 2 || h.depth === 3) || [];
---

<Layout title={`${post.data.title} | STUDIO`} description={post.data.description}>
  <article class="journal-detail">
    
    {/* Hero Section */}
    <div class="hero-section">
      <div class="container">
        <div class="hero-content">
          <div class="post-meta">
            <time datetime={post.data.date.toISOString()} class="post-date">
              {formattedDate}
            </time>
            <span class="meta-separator">•</span>
            <span class="read-time">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="1.5"/>
                <path d="M12 6V12L16 14" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round"/>
              </svg>
              {readTime} min read
            </span>
          </div>
          
          <h1 class="post-title">{post.data.title}</h1>
          
          {post.data.description && (
            <p class="post-excerpt">{post.data.description}</p>
          )}
          
          <div class="post-tags">
            {(post.data.tags || []).map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      </div>
      
      {/* Hero Image */}
      {post.data.heroImage && (
        <div class="hero-image">
          <img 
            src={post.data.heroImage} 
            alt={post.data.title}
            loading="eager"
          />
          {post.data.imageCaption && (
            <div class="image-caption">{post.data.imageCaption}</div>
          )}
        </div>
      )}
    </div>

    {/* Content Section with Sidebar */}
    <div class="content-section">
      <div class="container">
        <div class="content-layout">
          
          {/* Table of Contents Sidebar */}
          {tocHeadings.length > 0 && (
            <aside class="toc-sidebar">
              <div class="toc-wrapper">
                <div class="toc-header">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                    <path d="M4 6H20M4 12H20M4 18H20" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round"/>
                    <path d="M8 8V4M12 8V4M16 8V4" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round"/>
                  </svg>
                  <span>Contents</span>
                </div>
                <nav class="toc-nav">
                  {tocHeadings.map((heading: any) => (
                    <a 
                      href={`#${heading.slug}`} 
                      class={`toc-link depth-${heading.depth}`}
                      data-heading-id={heading.slug}
                    >
                      {heading.text}
                    </a>
                  ))}
                </nav>
              </div>
            </aside>
          )}
          
          {/* Main Content */}
          <div class="main-content">
            <div class="prose-container">
              <Content />
            </div>
            
            {/* Share Section */}
            <div class="share-section">
              <div class="share-divider"></div>
              <div class="share-content">
                <span class="share-label">Share</span>
                <div class="share-buttons">
                  <button class="share-btn twitter" id="shareTwitter" aria-label="Share on Twitter">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                      <path d="M23 3C22.1 3.9 21 4.4 19.8 4.6C19.1 3.9 18.1 3.5 17 3.5C14.9 3.5 13.2 5.2 13.2 7.3C13.2 7.6 13.2 7.9 13.3 8.2C10.2 8 7.5 6.6 5.6 4.3C4.8 5.6 4.8 7.2 5.7 8.3C4.9 8.3 4.2 8.1 3.6 7.7C3.6 9.3 4.8 10.7 6.3 11C5.6 11.2 4.8 11.2 4.1 11C4.5 12.4 5.8 13.4 7.3 13.4C6.1 14.3 4.6 14.8 3 14.8C2.7 14.8 2.3 14.8 2 14.7C3.5 15.7 5.3 16.3 7.2 16.3C14 16.3 17.6 10.7 17.6 5.8C17.6 5.6 17.6 5.4 17.6 5.2C18.5 4.5 19.3 3.8 20 3H23Z" fill="currentColor"/>
                    </svg>
                  </button>
                  <button class="share-btn linkedin" id="shareLinkedin" aria-label="Share on LinkedIn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                      <path d="M16 8C18.2091 8 20 9.79086 20 12V20H16V12C16 10.8954 15.1046 10 14 10C12.8954 10 12 10.8954 12 12V20H8V12C8 9.79086 9.79086 8 12 8C13.1046 8 14 8.89543 14 10C14 8.89543 14.8954 8 16 8Z" fill="currentColor"/>
                      <rect x="4" y="8" width="4" height="12" fill="currentColor"/>
                      <circle cx="6" cy="4" r="2" fill="currentColor"/>
                    </svg>
                  </button>
                  <button class="share-btn copy" id="copyLinkBtn" aria-label="Copy link">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                      <path d="M8 5H6C4.89543 5 4 5.89543 4 7V19C4 20.1046 4.89543 21 6 21H16C17.1046 21 18 20.1046 18 19V17" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round"/>
                      <path d="M10 13H20M20 13L16 9M20 13L16 17" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"/>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
            
            {/* Author Section */}
            {post.data.author && (
              <div class="author-section">
                <div class="author-card">
                  {post.data.authorAvatar && (
                    <img 
                      src={post.data.authorAvatar} 
                      alt={post.data.author}
                      class="author-avatar"
                    />
                  )}
                  <div class="author-info">
                    <h4 class="author-name">{post.data.author}</h4>
                    {post.data.authorBio && (
                      <p class="author-bio">{post.data.authorBio}</p>
                    )}
                  </div>
                </div>
              </div>
            )}
            
            {/* Navigation */}
            <div class="post-navigation">
              <a href="/journal" class="back-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path d="M19 12H5M5 12L12 19M5 12L12 5" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"/>
                </svg>
                Back to Journal
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
    
  </article>
</Layout>

<script>
  // Copy link functionality
  const copyBtn = document.getElementById('copyLinkBtn');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const originalHtml = copyBtn.innerHTML;
        copyBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17L4 12" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/></svg>';
        setTimeout(() => {
          copyBtn.innerHTML = originalHtml;
        }, 2000);
      } catch (err) {
        console.error('Failed to copy:', err);
      }
    });
  }
  
  // Share functionality
  function initShare() {
    const shareTwitter = document.getElementById('shareTwitter');
    const shareLinkedin = document.getElementById('shareLinkedin');
    const currentUrl = window.location.href;
    const postTitle = document.querySelector('.post-title')?.textContent || '';
    
    if (shareTwitter) {
      shareTwitter.addEventListener('click', () => {
        window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(postTitle)}&url=${encodeURIComponent(currentUrl)}`, '_blank');
      });
    }
    
    if (shareLinkedin) {
      shareLinkedin.addEventListener('click', () => {
        window.open(`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(currentUrl)}&title=${encodeURIComponent(postTitle)}`, '_blank');
      });
    }
  }
  
  // Table of contents scroll spy
  const tocLinks = document.querySelectorAll('.toc-link');
  const headings = document.querySelectorAll('.prose-container h2, .prose-container h3');
  
  if (tocLinks.length > 0 && headings.length > 0) {
    const observerOptions = {
      threshold: 0.3,
      rootMargin: '0px 0px -20% 0px'
    };
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          tocLinks.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('data-heading-id') === id) {
              link.classList.add('active');
            }
          });
        }
      });
    }, observerOptions);
    
    headings.forEach(heading => {
      if (heading.id) {
        observer.observe(heading);
      }
    });
  }
  
  // Smooth scroll for TOC links
  tocLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const targetId = link.getAttribute('data-heading-id');
      const targetElement = document.getElementById(targetId);
      if (targetElement) {
        targetElement.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
        history.pushState(null, '', `#${targetId}`);
      }
    });
  });
  
  // Initialize share
  initShare();
  
  // Re-initialize on Astro page load
  document.addEventListener('astro:page-load', () => {
    initShare();
  });
</script>

