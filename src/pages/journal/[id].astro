---
// [id].astro - Journal Detail Page
// Clean blog post layout with TOC and author section - Share removed
// Converted to Tailwind CSS only
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('journal');
  return posts.map((post: any) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Format date
const formattedDate = post.data.date.toLocaleDateString('en-US', { 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});

// Estimate read time
const readTime = post.data.readTime || Math.ceil((post.body?.length || 0) / 200 / 60) || 5;

// Get headings for table of contents
const tocHeadings = headings?.filter(h => h.depth === 2 || h.depth === 3) || [];
---

<Layout title={`${post.data.title} | STUDIO`} description={post.data.description}>
  <article class="journal-detail">
    
    {/* Hero Section */}
    <div class="hero-section">
      <div class="max-w-[1280px] mx-auto px-8 max-md:px-5">
        <div class="hero-content">
          <div class="flex items-center justify-center gap-2 flex-wrap mb-6">
            <time datetime={post.data.date.toISOString()} class="text-sm uppercase tracking-[0.05em] text-white/45">
              {formattedDate}
            </time>
            <span class="text-white/20">•</span>
            <span class="inline-flex items-center gap-1 text-sm text-white/45">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                <path d="M12 6V12L16 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              {readTime} min read
            </span>
          </div>
          
          <h1 class="post-title">{post.data.title}</h1>
          
          {post.data.description && (
            <p class="post-excerpt">{post.data.description}</p>
          )}
          
          <div class="flex flex-wrap justify-center gap-2">
            {(post.data.tags || []).map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      </div>
      
      {/* Hero Image */}
      {post.data.heroImage && (
        <div class="hero-image">
          <img 
            src={post.data.heroImage} 
            alt={post.data.title}
            loading="eager"
            class="w-full h-auto rounded-2xl shadow-[0_20px_40px_rgba(0,0,0,0.3)]"
          />
          {post.data.imageCaption && (
            <div class="image-caption">{post.data.imageCaption}</div>
          )}
        </div>
      )}
    </div>

    {/* Content Section with Sidebar */}
    <div class="content-section">
      <div class="max-w-[1280px] mx-auto px-8 max-md:px-5">
        <div class="content-layout">
          
          {/* Table of Contents Sidebar */}
          {tocHeadings.length > 0 && (
            <aside class="toc-sidebar">
              <div class="toc-wrapper">
                <div class="flex items-center gap-2 text-[0.7rem] font-semibold uppercase tracking-[0.1em] text-white/50 pb-3 border-b border-white/6 mb-3">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                    <path d="M4 6H20M4 12H20M4 18H20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M8 8V4M12 8V4M16 8V4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                  <span>Contents</span>
                </div>
                <nav class="flex flex-col gap-2">
                  {tocHeadings.map((heading: any) => (
                    <a 
                      href={`#${heading.slug}`} 
                      class={`toc-link depth-${heading.depth}`}
                      data-heading-id={heading.slug}
                    >
                      {heading.text}
                    </a>
                  ))}
                </nav>
              </div>
            </aside>
          )}
          
          {/* Main Content */}
          <div class="flex-1 min-w-0">
            <div class="prose-container">
              <Content />
            </div>
            
            {/* Author Section */}
            {post.data.author && (
              <div class="author-section">
                <div class="author-card">
                  {post.data.authorAvatar && (
                    <img 
                      src={post.data.authorAvatar} 
                      alt={post.data.author}
                      class="author-avatar"
                    />
                  )}
                  <div class="flex-1">
                    <h4 class="text-base font-semibold text-white mb-1">{post.data.author}</h4>
                    {post.data.authorBio && (
                      <p class="text-sm text-white/50 leading-relaxed">{post.data.authorBio}</p>
                    )}
                  </div>
                </div>
              </div>
            )}
            
            {/* Navigation */}
            <div class="text-center mt-12">
              <a href="/journal" class="back-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path d="M19 12H5M5 12L12 19M5 12L12 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Back to Journal
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
    
  </article>
</Layout>

<script>
  // Table of contents scroll spy
  const tocLinks = document.querySelectorAll('.toc-link');
  const headings = document.querySelectorAll('.prose-container h2, .prose-container h3');
  
  if (tocLinks.length > 0 && headings.length > 0) {
    const observerOptions = {
      threshold: 0.3,
      rootMargin: '0px 0px -20% 0px'
    };
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          tocLinks.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('data-heading-id') === id) {
              link.classList.add('active');
            }
          });
        }
      });
    }, observerOptions);
    
    headings.forEach(heading => {
      if (heading.id) {
        observer.observe(heading);
      }
    });
  }
  
  // Smooth scroll for TOC links
  tocLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const targetId = link.getAttribute('data-heading-id');
      const targetElement = document.getElementById(targetId);
      if (targetElement) {
        targetElement.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
        history.pushState(null, '', `#${targetId}`);
      }
    });
  });
</script>

<style is:global>
  /* ============================================
     ONLY ESSENTIAL CSS - Tailwind cannot do these
     Share section removed
     ============================================ */
  
  .journal-detail {
    position: relative;
  }
  
  /* Hero Section */
  .hero-section {
    padding: 6rem 0 2rem;
    background: linear-gradient(180deg, rgba(10, 10, 14, 0.8) 0%, rgba(10, 10, 14, 0) 100%);
  }
  
  @media (max-width: 768px) {
    .hero-section {
      padding: 4rem 0 1rem;
    }
  }
  
  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  
  .post-title {
    font-size: 3.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    color: #FFFFFF;
  }
  
  @media (max-width: 768px) {
    .post-title {
      font-size: 2.25rem;
    }
  }
  
  .post-excerpt {
    font-size: 1.25rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 1.5rem;
  }
  
  .tag {
    padding: 0.25rem 0.75rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 50px;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.6);
  }
  
  .hero-image {
    margin-top: 3rem;
    max-width: 1000px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .image-caption {
    text-align: center;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    margin-top: 0.75rem;
  }
  
  /* Content Section */
  .content-section {
    padding: 4rem 0 6rem;
  }
  
  @media (max-width: 768px) {
    .content-section {
      padding: 2rem 0 4rem;
    }
  }
  
  .content-layout {
    display: flex;
    gap: 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  @media (max-width: 1024px) {
    .content-layout {
      flex-direction: column;
    }
  }
  
  /* Table of Contents Sidebar */
  .toc-sidebar {
    flex-shrink: 0;
    width: 260px;
    position: sticky;
    top: 100px;
    align-self: start;
  }
  
  @media (max-width: 1024px) {
    .toc-sidebar {
      width: 100%;
      position: static;
      margin-bottom: 2rem;
    }
  }
  
  .toc-wrapper {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 0.75rem;
    padding: 1.25rem;
  }
  
  .toc-link {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: all 0.2s ease;
    padding: 0.25rem 0;
    line-height: 1.4;
  }
  
  .toc-link.depth-2 {
    padding-left: 0;
  }
  
  .toc-link.depth-3 {
    padding-left: 1rem;
    font-size: 0.8125rem;
  }
  
  .toc-link:hover {
    color: #A078FF;
  }
  
  .toc-link.active {
    color: #A078FF;
    font-weight: 500;
  }
  
  /* Prose Styles - Rich content formatting */
  .prose-container {
    max-width: 750px;
    margin: 0 auto;
    font-size: 1.125rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.85);
  }
  
  .prose-container h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-top: 2em;
    margin-bottom: 0.5em;
    color: #FFFFFF;
    letter-spacing: -0.02em;
  }
  
  .prose-container h2 {
    font-size: 1.75rem;
    font-weight: 600;
    margin-top: 2em;
    margin-bottom: 0.75em;
    color: #FFFFFF;
    letter-spacing: -0.02em;
  }
  
  .prose-container h3 {
    font-size: 1.375rem;
    font-weight: 600;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
    color: #FFFFFF;
  }
  
  .prose-container h4 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 1.25em;
    margin-bottom: 0.5em;
    color: #A078FF;
  }
  
  .prose-container p {
    margin-bottom: 1.25em;
  }
  
  .prose-container a {
    color: #A078FF;
    text-decoration: none;
    border-bottom: 1px solid rgba(160, 120, 255, 0.3);
    transition: border-color 0.2s ease;
  }
  
  .prose-container a:hover {
    border-bottom-color: #A078FF;
    color: #78FFD2;
  }
  
  .prose-container strong {
    color: #FFFFFF;
    font-weight: 600;
  }
  
  .prose-container code {
    background: rgba(255, 255, 255, 0.04);
    padding: 0.2em 0.4em;
    border-radius: 0.25rem;
    font-size: 0.875em;
    font-family: 'Monaco', 'Menlo', monospace;
  }
  
  .prose-container pre {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 0.75rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  
  .prose-container pre code {
    background: none;
    padding: 0;
  }
  
  .prose-container blockquote {
    border-left: 3px solid #A078FF;
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: rgba(255, 255, 255, 0.6);
  }
  
  .prose-container img {
    border-radius: 0.75rem;
    max-width: 100%;
    height: auto;
    margin: 1.5rem 0;
  }
  
  .prose-container ul,
  .prose-container ol {
    margin: 1.25rem 0;
    padding-left: 1.5rem;
  }
  
  .prose-container li {
    margin: 0.5rem 0;
  }
  
  .prose-container hr {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.08), transparent);
    margin: 2rem 0;
  }
  
  .prose-container table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }
  
  .prose-container th,
  .prose-container td {
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.75rem;
    text-align: left;
  }
  
  .prose-container th {
    background: rgba(255, 255, 255, 0.03);
    font-weight: 600;
  }
  
  /* Author Section */
  .author-section {
    margin: 3rem auto;
    max-width: 750px;
  }
  
  .author-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 0.75rem;
    transition: all 0.3s ease;
  }
  
  .author-card:hover {
    border-color: rgba(160, 120, 255, 0.2);
    background: rgba(255, 255, 255, 0.03);
  }
  
  @media (max-width: 480px) {
    .author-card {
      flex-direction: column;
      text-align: center;
    }
  }
  
  .author-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
  }
  
  /* Navigation */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 50px;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  
  .back-link:hover {
    background: rgba(160, 120, 255, 0.08);
    border-color: rgba(160, 120, 255, 0.2);
    color: #A078FF;
    transform: translateX(-4px);
  }
  
  @media (max-width: 768px) {
    .post-excerpt {
      font-size: 1rem;
    }
    
    .prose-container {
      font-size: 1rem;
    }
    
    .prose-container h1 {
      font-size: 1.75rem;
    }
    
    .prose-container h2 {
      font-size: 1.5rem;
    }
    
    .prose-container h3 {
      font-size: 1.25rem;
    }
    
    .prose-container table {
      font-size: 0.75rem;
    }
    
    .prose-container th,
    .prose-container td {
      padding: 0.5rem;
    }
  }
</style>