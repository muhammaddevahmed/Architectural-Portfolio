﻿---
// About.astro - About Page
// Modern about page with values, and studio story
// Converted to Tailwind CSS only
import Layout from '../layouts/Layout.astro';

// Values data
const values = [
  {
    icon: '🌿',
    title: 'Sustainability',
    description: 'Committed to eco-friendly practices and materials that minimize environmental impact.'
  },
  {
    icon: '🎨',
    title: 'Creativity',
    description: 'Pushing boundaries with innovative design solutions that inspire and delight.'
  },
  {
    icon: '🤝',
    title: 'Collaboration',
    description: 'Working closely with clients, artisans, and engineers to bring visions to life.'
  },
  {
    icon: '⭐',
    title: 'Excellence',
    description: 'Delivering the highest quality in every detail, from concept to completion.'
  }
];

// Milestones data
const milestones = [
  { year: '2012', title: 'Studio Founded', description: 'STUDIO opens its doors in San Francisco.' },
  { year: '2015', title: 'First Major Award', description: 'Recipient of the AIA Emerging Architecture Award.' },
  { year: '2018', title: 'International Expansion', description: 'Opens second studio in London.' },
  { year: '2021', title: 'Sustainability Focus', description: 'Launches dedicated sustainable design division.' },
  { year: '2024', title: 'Global Recognition', description: 'Named among World\'s Best Architecture Firms.' }
];
---

<Layout title="About | STUDIO" description="Learn about our studio's philosophy, values, and the passionate team behind our award-winning architectural designs.">
  
  <section class="py-24 max-md:py-16 relative">
    <div class="max-w-[1280px] mx-auto px-8 max-md:px-5">
      
      <!-- Hero Section -->
      <div class="text-center mb-20 reveal">
        <div class="inline-block px-4 py-1 bg-[rgba(160,120,255,0.1)] border border-[rgba(160,120,255,0.2)] rounded-full text-[0.75rem] font-medium text-[#A078FF] mb-4">Our Story</div>
        <h1 class="text-[2.5rem] max-md:text-[2.5rem] text-[3.5rem] font-bold tracking-[-0.03em] bg-gradient-to-br from-white to-[#A078FF] bg-clip-text text-transparent mb-4">About the Studio</h1>
        <p class="text-[1.125rem] text-white/60 max-w-[600px] mx-auto leading-relaxed">
          Founded in 2012, STUDIO is an architectural practice that seeks to find the balance 
          between built environments and the natural world.
        </p>
      </div>

      <!-- Philosophy Section -->
      <div class="mb-24 reveal-delay-1">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 max-lg:gap-8 items-start">
          <div>
            <h2 class="text-2xl max-md:text-1.75rem text-[2rem] font-bold mb-6">Designing Spaces That Inspire</h2>
            <div class="text-white/70 leading-relaxed mb-8 space-y-4">
              <p>
                Our philosophy is rooted in the belief that spaces profoundly influence human behavior 
                and well-being. We embrace a reductive approach, stripping away the superfluous to 
                reveal the essence of structure, light, and material.
              </p>
              <p>
                We work closely with artisans, engineers, and clients to craft bespoke spaces that 
                stand the test of time, both aesthetically and structurally.
              </p>
              <p>
                Every project is a unique opportunity to create something meaningful — a space that 
                resonates with its inhabitants and contributes positively to its surroundings.
              </p>
            </div>
            <div class="flex gap-8 mt-8">
              <div class="text-center">
                <div class="text-3xl font-bold bg-gradient-to-br from-white to-[#A078FF] bg-clip-text text-transparent">12+</div>
                <div class="text-[0.75rem] text-white/50 uppercase tracking-[0.05em]">Years of Excellence</div>
              </div>
              <div class="text-center">
                <div class="text-3xl font-bold bg-gradient-to-br from-white to-[#A078FF] bg-clip-text text-transparent">150+</div>
                <div class="text-[0.75rem] text-white/50 uppercase tracking-[0.05em]">Projects Completed</div>
              </div>
              <div class="text-center">
                <div class="text-3xl font-bold bg-gradient-to-br from-white to-[#A078FF] bg-clip-text text-transparent">25+</div>
                <div class="text-[0.75rem] text-white/50 uppercase tracking-[0.05em]">Industry Awards</div>
              </div>
            </div>
          </div>
          <div class="relative">
            <img 
              src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1200&q=80" 
              alt="Studio interior workspace"
              class="w-full h-auto rounded-2xl shadow-[0_20px_40px_rgba(0,0,0,0.3)]"
              loading="eager"
            />
            <div class="text-[0.75rem] text-white/40 text-center mt-3">Our San Francisco studio space</div>
          </div>
        </div>
      </div>

      <!-- Values Section -->
      <div class="mb-24 reveal-delay-2">
        <div class="text-center mb-12">
          <div class="text-[0.75rem] font-semibold uppercase tracking-[0.1em] text-[#A078FF] mb-4">Core Values</div>
          <h2 class="text-2xl max-md:text-2xl text-[2.5rem] font-bold tracking-[-0.02em] mb-4">What Drives Us</h2>
          <p class="text-[1.125rem] text-white/60 max-w-[600px] mx-auto">
            Our guiding principles shape every project we undertake and every relationship we build.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mt-8">
          {values.map((value, index) => (
            <div class="p-8 bg-white/3 border border-white/6 rounded-2xl text-center transition-all duration-300 hover:-translate-y-1 hover:border-[rgba(160,120,255,0.3)] hover:bg-white/5" style={`--value-index: ${index}`}>
              <div class="text-4xl mb-4">{value.icon}</div>
              <h3 class="text-xl font-semibold mb-3">{value.title}</h3>
              <p class="text-sm text-white/60 leading-relaxed">{value.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Timeline Section -->
      <div class="mb-24 reveal-delay-3">
        <div class="text-center mb-12">
          <div class="text-[0.75rem] font-semibold uppercase tracking-[0.1em] text-[#A078FF] mb-4">Our Journey</div>
          <h2 class="text-2xl max-md:text-2xl text-[2.5rem] font-bold tracking-[-0.02em]">Milestones</h2>
        </div>
        <div class="timeline-container relative max-w-[800px] mx-auto py-8">
          <div class="timeline-line"></div>
          {milestones.map((milestone, index) => (
            <div class="timeline-item-wrapper relative flex max-md:flex-col gap-8 mb-12 max-md:ml-10" style={`--milestone-index: ${index}`}>
              <div class="timeline-year shrink-0 w-[100px] max-md:w-auto text-xl font-bold text-[#A078FF]">{milestone.year}</div>
              <div class="timeline-content flex-1 p-4 px-6 bg-white/3 border border-white/6 rounded-2xl transition-all duration-300 hover:border-[rgba(160,120,255,0.3)] hover:bg-white/5">
                <h3 class="text-lg font-semibold mb-2">{milestone.title}</h3>
                <p class="text-sm text-white/60 leading-relaxed">{milestone.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA Section -->
      <div class="mt-16 reveal-delay-4">
        <div class="bg-gradient-to-br from-[rgba(160,120,255,0.1)] to-[rgba(120,255,210,0.05)] rounded-3xl p-16 max-md:p-8 text-center">
          <h2 class="text-2xl max-md:text-1.5rem text-[2rem] font-bold mb-4">Let's Create Together</h2>
          <p class="text-[1.125rem] text-white/70 mb-8">
            Ready to bring your architectural vision to life? We'd love to hear about your project.
          </p>
          <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-br from-[#A078FF] to-[#78FFD2] rounded-full text-[1rem] font-semibold text-[#0A0A0E] no-underline transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_20px_rgba(160,120,255,0.3)] hover:gap-3">
            Start a Conversation
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
      
    </div>
  </section>
</Layout>

<style is:global>
  /* ============================================
     ONLY ANIMATION KEYFRAMES - No other CSS
     ============================================ */
  
  .reveal {
    opacity: 0;
    animation: fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) forwards;
  }
  
  .reveal-delay-1 {
    opacity: 0;
    animation: fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) 0.1s forwards;
  }
  
  .reveal-delay-2 {
    opacity: 0;
    animation: fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) 0.2s forwards;
  }
  
  .reveal-delay-3 {
    opacity: 0;
    animation: fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) 0.3s forwards;
  }
  
  .reveal-delay-4 {
    opacity: 0;
    animation: fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) 0.4s forwards;
  }
  
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
    from {
      opacity: 0;
      transform: translateY(30px);
    }
  }
  
  /* Timeline line styling */
  .timeline-container {
    position: relative;
  }
  
  .timeline-line {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 100%;
    background: linear-gradient(180deg, #A078FF, #78FFD2);
    opacity: 0.3;
  }
  
  @media (max-width: 768px) {
    .timeline-line {
      left: 20px;
    }
  }
  
  .timeline-item-wrapper {
    position: relative;
  }
  
  @media (min-width: 769px) {
    .timeline-item-wrapper:nth-child(odd) {
      flex-direction: row;
    }
    
    .timeline-item-wrapper:nth-child(even) {
      flex-direction: row-reverse;
      text-align: right;
    }
    
    .timeline-item-wrapper:nth-child(even) .timeline-year {
      text-align: right;
    }
  }
</style>