﻿---
// 404.astro - Custom 404 Error Page
// Modern error page with glassmorphism and helpful navigation
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found | STUDIO" description="The page you're looking for doesn't exist. Let's get you back on track.">
  
  <section class="error-page">
    <div class="container">
      
      <!-- Animated Background Elements -->
      <div class="error-background">
        <div class="floating-shape shape-1"></div>
        <div class="floating-shape shape-2"></div>
        <div class="floating-shape shape-3"></div>
      </div>
      
      <!-- Error Content -->
      <div class="error-content">
        <div class="error-code-wrapper">
          <div class="error-code">
            <span class="digit">4</span>
            <span class="digit">0</span>
            <span class="digit">4</span>
          </div>
          <div class="error-glow"></div>
        </div>
        
        <h1 class="error-title">Page Not Found</h1>
        <p class="error-description">
          Oops! It seems like the page you're looking for has wandered off into the architectural void.
        </p>
        
        <div class="error-actions">
          <a href="/" class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M3 12H21M3 12L10 5M3 12L10 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Back to Home
          </a>
          <a href="/projects" class="btn-secondary">
            Browse Projects
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        
        <!-- Helpful Links -->
        <div class="helpful-links">
          <p class="helpful-title">You might find what you're looking for here:</p>
          <div class="links-grid">
            <a href="/" class="helpful-link">Home</a>
            <a href="/projects" class="helpful-link">Projects</a>
            <a href="/journal" class="helpful-link">Journal</a>
            <a href="/about" class="helpful-link">About</a>
            <a href="/contact" class="helpful-link">Contact</a>
          </div>
        </div>
        
        <!-- Search Suggestion -->
        <div class="search-suggestion">
          <p class="search-text">Or try searching:</p>
          <div class="search-wrapper">
            <form action="/search" method="GET" class="search-form">
              <input 
                type="text" 
                name="q" 
                placeholder="Search our studio..."
                class="search-input"
                aria-label="Search"
              />
              <button type="submit" class="search-button">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M15 15L21 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </button>
            </form>
          </div>
        </div>
      </div>
      
    </div>
  </section>
</Layout>

<style is:global>
  /* ============================================
     404 ERROR PAGE - Modern Glassmorphism Design
     ============================================ */
  
  .error-page {
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding: 4rem 0;
  }
  
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    width: 100%;
    position: relative;
    z-index: 2;
  }
  
  @media (max-width: 768px) {
    .container {
      padding: 0 1.25rem;
    }
  }
  
  /* ===== Animated Background ===== */
  .error-background {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  
  .floating-shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.3;
    animation: float 20s ease-in-out infinite;
  }
  
  .shape-1 {
    top: -100px;
    left: -100px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(160, 120, 255, 0.4), transparent);
    animation-delay: 0s;
  }
  
  .shape-2 {
    bottom: -100px;
    right: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(120, 255, 210, 0.3), transparent);
    animation-delay: -7s;
  }
  
  .shape-3 {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1), transparent);
    animation-delay: -14s;
  }
  
  @keyframes float {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(30px, -30px) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.9);
    }
  }
  
  /* ===== Error Content ===== */
  .error-content {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }
  
  /* Error Code Animation */
  .error-code-wrapper {
    position: relative;
    margin-bottom: 2rem;
  }
  
  .error-code {
    font-size: 8rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    display: flex;
    justify-content: center;
    gap: 0.25rem;
    position: relative;
    z-index: 2;
  }
  
  @media (max-width: 768px) {
    .error-code {
      font-size: 5rem;
    }
  }
  
  .digit {
    display: inline-block;
    background: linear-gradient(135deg, #A078FF, #78FFD2);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: bounceIn 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) forwards;
    opacity: 0;
    transform: scale(0);
  }
  
  .digit:nth-child(1) {
    animation-delay: 0.1s;
  }
  
  .digit:nth-child(2) {
    animation-delay: 0.2s;
  }
  
  .digit:nth-child(3) {
    animation-delay: 0.3s;
  }
  
  @keyframes bounceIn {
    0% {
      opacity: 0;
      transform: scale(0);
    }
    50% {
      opacity: 1;
      transform: scale(1.1);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }
  
  .error-glow {
    position: absolute;
    inset: -20px;
    background: radial-gradient(ellipse at center, rgba(160, 120, 255, 0.15), transparent 70%);
    border-radius: 50%;
    filter: blur(30px);
    animation: pulse 3s ease-in-out infinite;
  }
  
  @keyframes pulse {
    0%, 100% {
      opacity: 0.5;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.05);
    }
  }
  
  /* Error Title & Description */
  .error-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
    animation: fadeInUp 0.6s ease 0.4s forwards;
    opacity: 0;
    transform: translateY(20px);
  }
  
  @media (max-width: 768px) {
    .error-title {
      font-size: 1.5rem;
    }
  }
  
  .error-description {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 2rem;
    line-height: 1.6;
    animation: fadeInUp 0.6s ease 0.5s forwards;
    opacity: 0;
    transform: translateY(20px);
  }
  
  /* Action Buttons */
  .error-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
    animation: fadeInUp 0.6s ease 0.6s forwards;
    opacity: 0;
    transform: translateY(20px);
  }
  
  .btn-primary, .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    border-radius: 50px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  
  .btn-primary {
    background: linear-gradient(135deg, #A078FF, #78FFD2);
    color: #0A0A0E;
  }
  
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(160, 120, 255, 0.3);
    gap: 0.75rem;
  }
  
  .btn-secondary {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #FFFFFF;
  }
  
  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-2px);
    gap: 0.75rem;
  }
  
  /* Helpful Links */
  .helpful-links {
    margin-bottom: 2rem;
    animation: fadeInUp 0.6s ease 0.7s forwards;
    opacity: 0;
    transform: translateY(20px);
  }
  
  .helpful-title {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1rem;
  }
  
  .links-grid {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .helpful-link {
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 50px;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  
  .helpful-link:hover {
    border-color: rgba(160, 120, 255, 0.3);
    background: rgba(160, 120, 255, 0.1);
    color: #A078FF;
    transform: translateY(-2px);
  }
  
  /* Search Suggestion */
  .search-suggestion {
    animation: fadeInUp 0.6s ease 0.8s forwards;
    opacity: 0;
    transform: translateY(20px);
  }
  
  .search-text {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.75rem;
  }
  
  .search-wrapper {
    max-width: 400px;
    margin: 0 auto;
  }
  
  .search-form {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 50px;
    overflow: hidden;
    transition: all 0.2s ease;
  }
  
  .search-form:focus-within {
    border-color: rgba(160, 120, 255, 0.5);
    background: rgba(255, 255, 255, 0.05);
  }
  
  .search-input {
    flex: 1;
    padding: 0.875rem 1rem;
    background: transparent;
    border: none;
    font-size: 0.875rem;
    color: #FFFFFF;
    outline: none;
  }
  
  .search-input::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }
  
  .search-button {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1rem;
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .search-button:hover {
    color: #A078FF;
  }
  
  /* Animation Keyframes */
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
    from {
      opacity: 0;
      transform: translateY(20px);
    }
  }
  
  /* Reduce Motion Preference */
  @media (prefers-reduced-motion: reduce) {
    .floating-shape,
    .error-glow,
    .digit,
    .error-title,
    .error-description,
    .error-actions,
    .helpful-links,
    .search-suggestion {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
    
    .digit {
      transform: scale(1) !important;
    }
  }
  
  /* Responsive Adjustments */
  @media (max-width: 480px) {
    .error-actions {
      flex-direction: column;
      width: 100%;
    }
    
    .btn-primary,
    .btn-secondary {
      justify-content: center;
      width: 100%;
    }
    
    .links-grid {
      gap: 0.75rem;
    }
    
    .helpful-link {
      padding: 0.4rem 0.875rem;
      font-size: 0.75rem;
    }
  }
</style>