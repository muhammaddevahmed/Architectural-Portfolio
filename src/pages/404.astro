﻿---
// 404.astro - Custom 404 Error Page
// Modern error page with glassmorphism and helpful navigation
// Converted to Tailwind CSS only - Search bar removed
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found | STUDIO" description="The page you're looking for doesn't exist. Let's get you back on track.">
  
  <section class="min-h-[calc(100vh-80px)] flex items-center relative overflow-hidden py-16">
    <div class="max-w-[1280px] mx-auto px-8 max-md:px-5 w-full relative z-[2]">
      
      <!-- Animated Background Elements -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="shape-1"></div>
        <div class="shape-2"></div>
        <div class="shape-3"></div>
      </div>
      
      <!-- Error Content -->
      <div class="text-center max-w-[700px] mx-auto relative z-[2]">
        <div class="relative mb-8">
          <div class="text-8xl max-md:text-5xl font-extrabold tracking-[0.1em] flex justify-center gap-1 relative z-[2]">
            <span class="digit inline-block bg-gradient-to-br from-[#A078FF] to-[#78FFD2] bg-clip-text text-transparent animate-bounceIn" style="animation-delay: 0.1s">4</span>
            <span class="digit inline-block bg-gradient-to-br from-[#A078FF] to-[#78FFD2] bg-clip-text text-transparent animate-bounceIn" style="animation-delay: 0.2s">0</span>
            <span class="digit inline-block bg-gradient-to-br from-[#A078FF] to-[#78FFD2] bg-clip-text text-transparent animate-bounceIn" style="animation-delay: 0.3s">4</span>
          </div>
          <div class="error-glow"></div>
        </div>
        
        <h1 class="text-2xl max-md:text-1.5rem text-[2rem] font-bold mb-4 animate-fadeInUp" style="animation-delay: 0.4s">Page Not Found</h1>
        <p class="text-[1.125rem] text-white/60 mb-8 leading-relaxed animate-fadeInUp" style="animation-delay: 0.5s">
          Oops! It seems like the page you're looking for has wandered off into the architectural void.
        </p>
        
        <div class="flex justify-center gap-4 flex-wrap mb-12 animate-fadeInUp" style="animation-delay: 0.6s">
          <a href="/" class="inline-flex items-center gap-2 px-7 py-3.5 bg-gradient-to-br from-[#A078FF] to-[#78FFD2] rounded-full text-[0.875rem] font-semibold text-[#0A0A0E] no-underline transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_20px_rgba(160,120,255,0.3)] hover:gap-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M3 12H21M3 12L10 5M3 12L10 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Back to Home
          </a>
          <a href="/projects" class="inline-flex items-center gap-2 px-7 py-3.5 bg-white/5 border border-white/10 rounded-full text-[0.875rem] font-semibold text-white no-underline transition-all duration-300 hover:bg-white/10 hover:-translate-y-0.5 hover:gap-3">
            Browse Projects
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        
        <!-- Helpful Links -->
        <div class="mb-8 animate-fadeInUp" style="animation-delay: 0.7s">
          <p class="text-sm text-white/50 mb-4">You might find what you're looking for here:</p>
          <div class="flex justify-center flex-wrap gap-4">
            <a href="/" class="px-4 py-2 bg-white/3 border border-white/8 rounded-full text-sm text-white/70 no-underline transition-all duration-200 hover:border-[rgba(160,120,255,0.3)] hover:bg-[rgba(160,120,255,0.1)] hover:text-[#A078FF] hover:-translate-y-0.5">Home</a>
            <a href="/projects" class="px-4 py-2 bg-white/3 border border-white/8 rounded-full text-sm text-white/70 no-underline transition-all duration-200 hover:border-[rgba(160,120,255,0.3)] hover:bg-[rgba(160,120,255,0.1)] hover:text-[#A078FF] hover:-translate-y-0.5">Projects</a>
            <a href="/journal" class="px-4 py-2 bg-white/3 border border-white/8 rounded-full text-sm text-white/70 no-underline transition-all duration-200 hover:border-[rgba(160,120,255,0.3)] hover:bg-[rgba(160,120,255,0.1)] hover:text-[#A078FF] hover:-translate-y-0.5">Journal</a>
            <a href="/about" class="px-4 py-2 bg-white/3 border border-white/8 rounded-full text-sm text-white/70 no-underline transition-all duration-200 hover:border-[rgba(160,120,255,0.3)] hover:bg-[rgba(160,120,255,0.1)] hover:text-[#A078FF] hover:-translate-y-0.5">About</a>
            <a href="/contact" class="px-4 py-2 bg-white/3 border border-white/8 rounded-full text-sm text-white/70 no-underline transition-all duration-200 hover:border-[rgba(160,120,255,0.3)] hover:bg-[rgba(160,120,255,0.1)] hover:text-[#A078FF] hover:-translate-y-0.5">Contact</a>
          </div>
        </div>
        
      </div>
      
    </div>
  </section>
</Layout>

<style is:global>
  /* ============================================
     ONLY ANIMATIONS & SHAPES - No other CSS
     ============================================ */
  
  /* Floating shapes */
  .shape-1 {
    position: absolute;
    top: -100px;
    left: -100px;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(160, 120, 255, 0.4), transparent);
    filter: blur(60px);
    opacity: 0.3;
    animation: float 20s ease-in-out infinite;
    animation-delay: 0s;
  }
  
  .shape-2 {
    position: absolute;
    bottom: -100px;
    right: -100px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(120, 255, 210, 0.3), transparent);
    filter: blur(60px);
    opacity: 0.3;
    animation: float 20s ease-in-out infinite;
    animation-delay: -7s;
  }
  
  .shape-3 {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1), transparent);
    filter: blur(60px);
    opacity: 0.3;
    animation: float 20s ease-in-out infinite;
    animation-delay: -14s;
  }
  
  .error-glow {
    position: absolute;
    inset: -20px;
    background: radial-gradient(ellipse at center, rgba(160, 120, 255, 0.15), transparent 70%);
    border-radius: 50%;
    filter: blur(30px);
    animation: pulse 3s ease-in-out infinite;
  }
  
  /* Animations */
  @keyframes float {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(30px, -30px) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.9);
    }
  }
  
  @keyframes pulse {
    0%, 100% {
      opacity: 0.5;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.05);
    }
  }
  
  @keyframes bounceIn {
    0% {
      opacity: 0;
      transform: scale(0);
    }
    50% {
      opacity: 1;
      transform: scale(1.1);
    }
    100% {
      opacity: 1;
      transform: scale(1);
    }
  }
  
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
    from {
      opacity: 0;
      transform: translateY(20px);
    }
  }
  
  /* Animation Classes */
  .animate-bounceIn {
    opacity: 0;
    transform: scale(0);
    animation: bounceIn 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) forwards;
  }
  
  .animate-fadeInUp {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.6s ease forwards;
  }
  
  /* Digit styles */
  .digit {
    display: inline-block;
  }
  
  /* Reduce Motion Preference */
  @media (prefers-reduced-motion: reduce) {
    .shape-1,
    .shape-2,
    .shape-3,
    .error-glow,
    .digit,
    .animate-bounceIn,
    .animate-fadeInUp {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
    
    .digit {
      transform: scale(1) !important;
    }
  }
  
  /* Responsive Adjustments */
  @media (max-width: 480px) {
    .flex.justify-center.gap-4 {
      flex-direction: column;
      width: 100%;
    }
    
    .inline-flex.items-center.gap-2 {
      justify-content: center;
      width: 100%;
    }
    
    .flex.justify-center.flex-wrap.gap-4 {
      gap: 0.75rem;
    }
  }
</style>