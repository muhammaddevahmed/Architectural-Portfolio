﻿---
// Index.astro - Homepage
// Modern portfolio homepage with 2 featured projects
// Converted to Tailwind CSS
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects')) || [];
const featuredProjects = allProjects.slice(0, 2);

// Services data
const services = [
  {
    icon: '🏛️',
    title: 'Architecture',
    description: 'Creating timeless structures that blend functionality with aesthetic excellence.'
  },
  {
    icon: '🏠',
    title: 'Interior Design',
    description: 'Crafting immersive interior experiences that reflect your unique vision.'
  },
  {
    icon: '🌿',
    title: 'Sustainable Design',
    description: 'Eco-conscious solutions that minimize environmental impact without compromising beauty.'
  },
  {
    icon: '📐',
    title: 'Urban Planning',
    description: 'Shaping communities through thoughtful, human-centered urban design.'
  }
];

// Stats data
const stats = [
  { value: '12+', label: 'Years of Excellence' },
  { value: '150+', label: 'Projects Completed' },
  { value: '25+', label: 'Industry Awards' },
  { value: '45+', label: 'Happy Clients' }
];
---

<Layout title="STUDIO | Architecture & Design" description="An award-winning architecture and design studio focused on minimalist, sustainable, and context-driven spaces.">
  
  <!-- Hero Section -->
  <section class="min-h-[90vh] flex items-center relative py-24 pb-16">
    <div class="max-w-[1280px] mx-auto px-8 max-md:px-5">
      <div class="max-w-[900px] mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-[rgba(160,120,255,0.1)] border border-[rgba(160,120,255,0.2)] rounded-full text-[0.75rem] font-medium text-[#A078FF] mb-8 reveal">
          <span class="w-1.5 h-1.5 bg-[#78FFD2] rounded-full inline-block"></span>
          Award-winning architecture studio
        </div>
        <h1 class="text-[2.75rem] max-md:text-[2.75rem] text-[4.5rem] font-bold leading-[1.1] tracking-[-0.03em] mb-6 reveal-delay-1">
          Shaping environments
          <span class="bg-gradient-to-br from-[#A078FF] to-[#78FFD2] bg-clip-text text-transparent">that inspire.</span>
        </h1>
        <p class="text-[1.125rem] max-md:text-[1.125rem] text-[1.25rem] text-white/70 max-w-[600px] mx-auto mb-8 leading-relaxed reveal-delay-2">
          An award-winning architecture and design studio focused on minimalist, 
          sustainable, and context-driven spaces that stand the test of time.
        </p>
        <div class="flex gap-4 justify-center flex-wrap reveal-delay-3">
          <a href="/projects" class="inline-flex items-center gap-2 px-7 py-3.5 bg-gradient-to-br from-[#A078FF] to-[#78FFD2] rounded-full text-[0.875rem] font-semibold text-[#0A0A0E] no-underline transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_20px_rgba(160,120,255,0.3)] hover:gap-3">
            View Our Work
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 px-7 py-3.5 bg-white/5 border border-white/10 rounded-full text-[0.875rem] font-semibold text-white no-underline transition-all duration-300 hover:bg-white/10 hover:-translate-y-0.5 hover:gap-3">
            Let's Talk
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M3 8L10.5 13.5C11.2 14 12.8 14 13.5 13.5L21 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-[0.75rem] text-white/40 reveal-delay-4">
        <span>Scroll to explore</span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M12 5V19M12 19L5 12M12 19L19 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- Featured Projects Section - Exactly 2 Projects -->
  <section class="py-24">
    <div class="max-w-[1280px] mx-auto px-8 max-md:px-5">
      <div class="mb-12">
        <div class="text-[0.75rem] font-semibold uppercase tracking-[0.1em] text-[#A078FF] mb-4 reveal">Featured Works</div>
        <div class="flex justify-between items-end flex-wrap gap-4">
          <h2 class="text-[2rem] max-md:text-[2rem] text-[2.5rem] font-bold tracking-[-0.02em] reveal-delay-1">Selected Projects</h2>
          <a href="/projects" class="inline-flex items-center gap-2 text-[0.875rem] font-medium text-white/70 no-underline transition-all duration-300 hover:text-[#A078FF] hover:gap-3 reveal-delay-2">
            View All Projects
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-[1000px] mx-auto">
        {featuredProjects.map((project: any, index: number) => (
          <a href={`/projects/${project.id}`} class="block no-underline transition-all duration-300 hover:-translate-y-1 reveal-delay-3" style={`--card-index: ${index}`}>
            <div class="relative overflow-hidden rounded-2xl mb-5 aspect-[4/3]">
              <img 
                src={project.data.image} 
                alt={project.data.title} 
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading={index === 0 ? "eager" : "lazy"}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent opacity-0 transition-opacity duration-300 hover:opacity-100 flex items-end p-6">
                <div class="flex justify-between items-center w-full">
                  <span class="text-[0.75rem] font-medium text-white/80">{project.data.category}</span>
                  <span class="inline-flex items-center gap-2 text-[0.875rem] font-medium text-white">
                    View Project
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                      <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </div>
              </div>
            </div>
            <div class="flex justify-between items-start gap-4">
              <div>
                <h3 class="text-xl font-semibold text-white mb-2 transition-colors duration-300 group-hover:text-[#A078FF]">{project.data.title}</h3>
                <p class="text-sm text-white/60 leading-relaxed">{project.data.description}</p>
              </div>
              <span class="px-3 py-1 bg-white/5 border border-white/8 rounded-full text-[0.7rem] text-white/70 whitespace-nowrap">{project.data.category}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-24 bg-gradient-to-b from-transparent via-[rgba(160,120,255,0.03)] to-transparent">
    <div class="max-w-[1280px] mx-auto px-8 max-md:px-5">
      <div class="text-center mb-12">
        <div class="text-[0.75rem] font-semibold uppercase tracking-[0.1em] text-[#A078FF] mb-4 reveal">What We Do</div>
        <h2 class="text-[2rem] max-md:text-[2rem] text-[2.5rem] font-bold tracking-[-0.02em] reveal-delay-1">Comprehensive Design Services</h2>
        <p class="text-[1.125rem] text-white/60 max-w-[600px] mx-auto mt-4 reveal-delay-2">
          From concept to completion, we deliver exceptional design solutions tailored to your needs.
        </p>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mt-12">
        {services.map((service, index) => (
          <div class="p-8 bg-white/3 border border-white/6 rounded-2xl transition-all duration-300 hover:-translate-y-1 hover:border-[rgba(160,120,255,0.3)] hover:bg-white/5 reveal-delay-3" style={`--service-index: ${index}`}>
            <div class="text-4xl mb-5">{service.icon}</div>
            <h3 class="text-xl font-semibold mb-3">{service.title}</h3>
            <p class="text-sm text-white/60 leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-16">
    <div class="max-w-[1280px] mx-auto px-8 max-md:px-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 text-center">
        {stats.map((stat, index) => (
          <div class="reveal-delay-1" style={`--stat-index: ${index}`}>
            <div class="text-5xl font-bold bg-gradient-to-br from-white to-[#A078FF] bg-clip-text text-transparent mb-2">{stat.value}</div>
            <div class="text-sm text-white/50 uppercase tracking-[0.05em]">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Philosophy Section -->
  <section class="py-24">
    <div class="max-w-[1280px] mx-auto px-8 max-md:px-5">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="text-[0.75rem] font-semibold uppercase tracking-[0.1em] text-[#A078FF] mb-4 reveal">Our Philosophy</div>
          <h2 class="text-[2rem] max-md:text-[2rem] text-[2.5rem] font-bold leading-[1.2] mb-6 reveal-delay-1">
            Designing for people,
            <span class="bg-gradient-to-br from-[#A078FF] to-[#78FFD2] bg-clip-text text-transparent">building for the future.</span>
          </h2>
          <p class="text-[1.125rem] text-white/70 leading-relaxed mb-8 reveal-delay-2">
            We believe that great architecture is more than just aesthetics—it's about creating spaces 
            that enhance human experience, respect the environment, and inspire generations to come.
          </p>
          <div class="reveal-delay-3">
            <a href="/about" class="inline-flex items-center gap-2 px-7 py-3.5 bg-white/5 border border-white/10 rounded-full text-[0.875rem] font-semibold text-white no-underline transition-all duration-300 hover:bg-white/10 hover:-translate-y-0.5 hover:gap-3">
              Learn More About Us
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
        <div class="bg-gradient-to-br from-[rgba(160,120,255,0.1)] to-[rgba(120,255,210,0.05)] rounded-3xl aspect-square flex items-center justify-center border border-white/10 reveal-delay-4">
          <svg width="80" height="80" viewBox="0 0 24 24" fill="none" class="text-white/20">
            <path d="M12 2L2 7L12 12L22 7L12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M2 12L12 17L22 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="pt-16 pb-32">
    <div class="max-w-[1280px] mx-auto px-8 max-md:px-5">
      <div class="bg-gradient-to-br from-[rgba(160,120,255,0.1)] to-[rgba(120,255,210,0.05)] rounded-3xl p-16 max-md:p-8 text-center">
        <h2 class="text-2xl max-md:text-[1.5rem] text-[2rem] font-bold mb-4">Ready to bring your vision to life?</h2>
        <p class="text-[1.125rem] text-white/70 mb-8">
          Let's collaborate on your next project and create something extraordinary together.
        </p>
        <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-br from-[#A078FF] to-[#78FFD2] rounded-full text-[1rem] font-semibold text-[#0A0A0E] no-underline transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_20px_rgba(160,120,255,0.3)] hover:gap-3">
          Start a Conversation
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style is:global>
  /* ============================================
     ANIMATION STYLES - Preserved from original
     ============================================ */
  
  .reveal {
    opacity: 0;
    animation: fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) forwards;
  }
  
  .reveal-delay-1 {
    opacity: 0;
    animation: fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) 0.1s forwards;
  }
  
  .reveal-delay-2 {
    opacity: 0;
    animation: fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) 0.2s forwards;
  }
  
  .reveal-delay-3 {
    opacity: 0;
    animation: fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) 0.3s forwards;
  }
  
  .reveal-delay-4 {
    opacity: 0;
    animation: fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) 0.4s forwards;
  }
  
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
    from {
      opacity: 0;
      transform: translateY(30px);
    }
  }
  
  /* Group hover styles for project cards */
  .group:hover .group-hover\:scale-105 {
    transform: scale(1.05);
  }
  
  .group:hover .group-hover\:text-\[#A078FF\] {
    color: #A078FF;
  }
</style>