﻿---
// Contact.astro - Contact Page
// Modern contact page with form, contact info, and map
import Layout from '../layouts/Layout.astro';

// Contact information
const contactInfo = [
  {
    icon: '📍',
    title: 'Visit Us',
    details: ['123 Architecture Lane', 'San Francisco, CA 94105', 'United States']
  },
  {
    icon: '📞',
    title: 'Call Us',
    details: ['+1 (415) 555-0123', '+1 (415) 555-0124']
  },
  {
    icon: '✉️',
    title: 'Email Us',
    details: ['hello@studio.com', 'press@studio.com']
  },
  {
    icon: '🕒',
    title: 'Studio Hours',
    details: ['Monday - Friday: 9am - 6pm', 'Saturday: 10am - 4pm', 'Sunday: Closed']
  }
];

// Social links
const socialLinks = [
  { name: 'Instagram', icon: 'instagram', href: 'https://instagram.com' },
  { name: 'X', icon: 'twitter', href: 'https://twitter.com' },
  { name: 'LinkedIn', icon: 'linkedin', href: 'https://linkedin.com' },
  { name: 'Behance', icon: 'behance', href: 'https://behance.net' }
];
---

<Layout title="Contact | STUDIO" description="Get in touch with our studio. We're always open to discussing new projects, creative ideas, or opportunities.">
  
  <section class="contact-page">
    <div class="container">
      
      <!-- Page Header -->
      <div class="page-header reveal">
        <div class="header-badge">Let's Connect</div>
        <h1 class="page-title">Get in Touch</h1>
        <p class="page-description">
          We're always open to discussing new projects, creative ideas, or opportunities 
          to be part of your visions. Reach out and let's create something extraordinary together.
        </p>
      </div>

      <!-- Contact Grid -->
      <div class="contact-grid">
        
        <!-- Contact Information Cards -->
        <div class="contact-info-section reveal-delay-1">
          <div class="info-cards">
            {contactInfo.map((info, index) => (
              <div class="info-card" style={`--card-index: ${index}`}>
                <div class="info-icon">{info.icon}</div>
                <h3 class="info-title">{info.title}</h3>
                <div class="info-details">
                  {info.details.map((detail) => (
<p class="info-detail">{detail}</p>
                  ))}
                </div>
              </div>
            ))}
          </div>
          
          <!-- Social Links -->
          <div class="social-section">
            <h3 class="social-title">Follow Us</h3>
            <div class="social-links">
              {socialLinks.map((social) => (
                <a 
                  href={social.href} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="social-link"
                  aria-label={social.name}
                >
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                    {social.icon === 'instagram' && (
                      <path d="M17 2H7C4.23858 2 2 4.23858 2 7V17C2 19.7614 4.23858 22 7 22H17C19.7614 22 22 19.7614 22 17V7C22 4.23858 19.7614 2 17 2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    )}
                    {social.icon === 'twitter' && (
                      <path d="M23 3C22.1 3.9 21 4.4 19.8 4.6C19.1 3.9 18.1 3.5 17 3.5C14.9 3.5 13.2 5.2 13.2 7.3C13.2 7.6 13.2 7.9 13.3 8.2C10.2 8 7.5 6.6 5.6 4.3C4.8 5.6 4.8 7.2 5.7 8.3C4.9 8.3 4.2 8.1 3.6 7.7C3.6 9.3 4.8 10.7 6.3 11C5.6 11.2 4.8 11.2 4.1 11C4.5 12.4 5.8 13.4 7.3 13.4C6.1 14.3 4.6 14.8 3 14.8C2.7 14.8 2.3 14.8 2 14.7C3.5 15.7 5.3 16.3 7.2 16.3C14 16.3 17.6 10.7 17.6 5.8C17.6 5.6 17.6 5.4 17.6 5.2C18.5 4.5 19.3 3.8 20 3H23Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                    )}
                    {social.icon === 'linkedin' && (
                      <path d="M16 8C18.2091 8 20 9.79086 20 12V20H16V12C16 10.8954 15.1046 10 14 10C12.8954 10 12 10.8954 12 12V20H8V12C8 9.79086 9.79086 8 12 8C13.1046 8 14 8.89543 14 10C14 8.89543 14.8954 8 16 8Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                      <rect x="4" y="8" width="4" height="12" stroke="currentColor" stroke-width="1.5" fill="none"/>
                      <circle cx="6" cy="4" r="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
                    )}
                    {social.icon === 'behance' && (
                      <path d="M8 12H12M8 8H12M16 15C16 13.8954 15.1046 13 14 13H12V17H14C15.1046 17 16 16.1046 16 15Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                      <path d="M12 8V13M12 8H15C16.1046 8 17 8.89543 17 10C17 11.1046 16.1046 12 15 12H12" stroke="currentColor" stroke-width="1.5" fill="none"/>
                      <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
                    )}
                  </svg>
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="contact-form-section reveal-delay-2">
          <div class="form-card glass">
            <h2 class="form-title">Send us a Message</h2>
            <p class="form-description">
              Fill out the form below and we'll get back to you within 24 hours.
            </p>
            
            <form 
              class="contact-form" 
action="https://formspree.io/f/placeholder"
              method="POST"
              id="contactForm"
            >
              <div class="form-row">
                <div class="form-group">
                  <label for="name" class="form-label">
                    Full Name <span class="required">*</span>
                  </label>
                  <input 
                    type="text" 
                    id="name" 
                    name="name" 
                    required 
                    class="form-input" 
                    placeholder="Jane Doe"
                  />
                </div>
                
                <div class="form-group">
                  <label for="email" class="form-label">
                    Email Address <span class="required">*</span>
                  </label>
                  <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    required 
                    class="form-input" 
                    placeholder="jane@example.com"
                  />
                </div>
              </div>
              
              <div class="form-row">
                <div class="form-group">
                  <label for="phone" class="form-label">Phone Number</label>
                  <input 
                    type="tel" 
                    id="phone" 
                    name="phone" 
                    class="form-input" 
                    placeholder="+1 (415) 555-0123"
                  />
                </div>
                
                <div class="form-group">
                  <label for="subject" class="form-label">
                    Subject <span class="required">*</span>
                  </label>
                  <input 
                    type="text" 
                    id="subject" 
                    name="subject" 
                    required 
                    class="form-input" 
                    placeholder="Project Inquiry"
                  />
                </div>
              </div>
              
              <div class="form-group full-width">
                <label for="message" class="form-label">
                  Message <span class="required">*</span>
                </label>
                <textarea 
                  id="message" 
                  name="message" 
                  rows="6" 
                  required 
                  class="form-textarea" 
                  placeholder="Tell us about your project, ideas, or how we can help..."
                ></textarea>
              </div>
              
              <div class="form-submit">
                <button type="submit" class="submit-btn">
                  <span>Send Message</span>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                    <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>
              
              <p class="form-note">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                  <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M12 16V12M12 8H12.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                We respect your privacy. Your information will never be shared.
              </p>
            </form>
          </div>
        </div>
      </div>

     

      <!-- FAQ Section -->
      <div class="faq-section reveal-delay-4">
        <div class="faq-header">
          <h2 class="faq-title">Frequently Asked Questions</h2>
          <p class="faq-description">Find quick answers to common questions about working with us.</p>
        </div>
        <div class="faq-grid">
          <div class="faq-item">
            <h3 class="faq-question">What is your typical project timeline?</h3>
            <p class="faq-answer">Project timelines vary depending on scope and complexity. Typically, residential projects take 4-8 months, while commercial projects may take 8-12 months.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-question">Do you work on international projects?</h3>
            <p class="faq-answer">Yes, we have experience working on projects globally. We can accommodate different time zones and coordinate remotely.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-question">What is your design process?</h3>
            <p class="faq-answer">Our process includes discovery, concept development, design development, documentation, and construction administration.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-question">Do you offer virtual consultations?</h3>
            <p class="faq-answer">Absolutely! We offer both in-person and virtual consultations to accommodate your preferences and location.</p>
          </div>
        </div>
      </div>
      
    </div>
  </section>
</Layout>

<script>
  // Form submission handling with loading state
  const form = document.getElementById('contactForm');
  
  if (form) {
    form.addEventListener('submit', async () => {
      const submitBtn = form.querySelector('.submit-btn') as HTMLButtonElement;
      const originalText = submitBtn.innerHTML;
      
      submitBtn.innerHTML = `
        <span>Sending...</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="spinner">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" stroke-dasharray="30 30"/>
        </svg>
      `;
      submitBtn.disabled = true;
      
      // Form will submit naturally to Formspree
      // Add loading animation only
      setTimeout(() => {
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
      }, 3000);
    });
  }
</script>

<style is:global>
  /* ============================================
     CONTACT PAGE STYLES - Modern Studio Contact
     ============================================ */
  
  .contact-page {
    padding: 6rem 0 8rem;
    position: relative;
  }
  
  @media (max-width: 768px) {
    .contact-page {
      padding: 4rem 0 6rem;
    }
  }
  
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  @media (max-width: 768px) {
    .container {
      padding: 0 1.25rem;
    }
  }
  
  /* ===== Page Header ===== */
  .page-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  
  .header-badge {
    display: inline-block;
    padding: 0.25rem 1rem;
    background: rgba(160, 120, 255, 0.1);
    border: 1px solid rgba(160, 120, 255, 0.2);
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 500;
    color: #A078FF;
    margin-bottom: 1rem;
  }
  
  .page-title {
    font-size: 3.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, #FFFFFF, #A078FF);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 1rem;
  }
  
  @media (max-width: 768px) {
    .page-title {
      font-size: 2.5rem;
    }
  }
  
  .page-description {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.6);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }
  
  /* ===== Contact Grid ===== */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }
  
  @media (max-width: 1000px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
  
  /* Contact Info Section */
  .contact-info-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  
  .info-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }
  
  .info-card {
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 1rem;
    transition: all 0.3s ease;
  }
  
  .info-card:hover {
    transform: translateY(-4px);
    border-color: rgba(160, 120, 255, 0.3);
    background: rgba(255, 255, 255, 0.05);
  }
  
  .info-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }
  
  .info-title {
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 0.75rem;
  }
  
  .info-details {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  
  .info-detail {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.4;
  }
  
  /* Social Section */
  .social-section {
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 1rem;
  }
  
  .social-title {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 1rem;
  }
  
  .social-links {
    display: flex;
    gap: 1rem;
  }
  
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.7);
    transition: all 0.2s ease;
  }
  
  .social-link:hover {
    transform: translateY(-2px);
    border-color: #A078FF;
    background: rgba(160, 120, 255, 0.1);
    color: #A078FF;
  }
  
  /* Contact Form Section */
  .form-card {
    padding: 2.5rem;
    border-radius: 1.5rem;
  }
  
  @media (max-width: 768px) {
    .form-card {
      padding: 1.5rem;
    }
  }
  
  .form-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  
  .form-description {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 2rem;
  }
  
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  
  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
  
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .form-group.full-width {
    grid-column: span 2;
  }
  
  @media (max-width: 640px) {
    .form-group.full-width {
      grid-column: span 1;
    }
  }
  
  .form-label {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.7);
  }
  
  .required {
    color: #A078FF;
  }
  
  .form-input,
  .form-textarea {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.75rem;
    padding: 0.875rem 1rem;
    font-size: 0.875rem;
    color: #FFFFFF;
    transition: all 0.2s ease;
  }
  
  .form-input:focus,
  .form-textarea:focus {
    outline: none;
    border-color: #A078FF;
    background: rgba(255, 255, 255, 0.05);
  }
  
  .form-input::placeholder,
  .form-textarea::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }
  
  .form-textarea {
    resize: vertical;
  }
  
  .form-submit {
    text-align: center;
  }
  
  .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #A078FF, #78FFD2);
    border: none;
    border-radius: 50px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #0A0A0E;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .submit-btn:hover {
    transform: translateY(-2px);
    gap: 0.75rem;
    filter: brightness(1.05);
  }
  
  .submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }
  
  .form-note {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.4);
    text-align: center;
  }
  
  /* ===== Map Section ===== */
  .map-section {
    margin-bottom: 4rem;
  }
  
  .map-card {
    padding: 2rem;
    border-radius: 1.5rem;
    text-align: center;
  }
  
  .map-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 3rem;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 1rem;
    color: rgba(255, 255, 255, 0.5);
  }
  
  .map-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(160, 120, 255, 0.1);
    border: 1px solid rgba(160, 120, 255, 0.2);
    border-radius: 50px;
    font-size: 0.875rem;
    color: #A078FF;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  
  .map-link:hover {
    background: rgba(160, 120, 255, 0.2);
    gap: 0.75rem;
  }
  
  /* ===== FAQ Section ===== */
  .faq-section {
    margin-top: 4rem;
  }
  
  .faq-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .faq-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  
  @media (max-width: 768px) {
    .faq-title {
      font-size: 1.5rem;
    }
  }
  
  .faq-description {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
  }
  
  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }
  
  .faq-item {
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 1rem;
    transition: all 0.3s ease;
  }
  
  .faq-item:hover {
    border-color: rgba(160, 120, 255, 0.2);
    background: rgba(255, 255, 255, 0.04);
  }
  
  .faq-question {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  
  .faq-answer {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.5;
  }
  
  /* ===== Animation Classes ===== */
  .reveal {
    opacity: 0;
    animation: fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) forwards;
  }
  
  .reveal-delay-1 {
    opacity: 0;
    animation: fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) 0.1s forwards;
  }
  
  .reveal-delay-2 {
    opacity: 0;
    animation: fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) 0.2s forwards;
  }
  
  .reveal-delay-3 {
    opacity: 0;
    animation: fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) 0.3s forwards;
  }
  
  .reveal-delay-4 {
    opacity: 0;
    animation: fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) 0.4s forwards;
  }
  
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
    from {
      opacity: 0;
      transform: translateY(30px);
    }
  }
  
  /* Spinner animation */
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
  
  .spinner {
    animation: spin 1s linear infinite;
  }
</style>