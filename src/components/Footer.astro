---
// Footer.astro - Colorful Tech Footer with Lighter Background
// Modern footer with vibrant gradient icons and lighter glassmorphism
// Converted to Tailwind CSS
const year = new Date().getFullYear();

const socialLinks = [
  { name: 'Instagram', icon: 'instagram', href: 'https://instagram.com', color: '#E4405F' },
  { name: 'X', icon: 'twitter', href: 'https://twitter.com', color: '#1DA1F2' },
  { name: 'LinkedIn', icon: 'linkedin', href: 'https://linkedin.com', color: '#0A66C2' },
  { name: 'GitHub', icon: 'github', href: 'https://github.com', color: '#FFFFFF' },
];
---

<footer class="relative bg-[rgba(25,25,32,0.92)] backdrop-blur-[12px] border-t border-white/10 mt-16 before:content-[''] before:absolute before:top-0 before:left-0 before:right-0 before:h-px before:bg-gradient-to-r before:from-transparent before:via-[rgba(160,120,255,0.5)] before:to-transparent">
  <div class="max-w-[1280px] mx-auto px-8 max-md:px-5 py-12 pb-6 relative z-[1]">
    
    <!-- Main Footer Content -->
    <div class="grid grid-cols-[1.6fr_0.8fr_1.2fr] max-[900px]:grid-cols-[1fr_1fr] max-sm:grid-cols-1 gap-8 max-[900px]:gap-6 mb-10">
      
      <!-- Brand Column -->
      <div class="flex flex-col gap-5 max-[900px]:col-span-2 max-sm:col-span-1">
        <a href="/" class="inline-flex items-center gap-3 no-underline w-fit">
          <div class="flex items-center">
            <svg width="40" height="40" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M16 2L2 9L16 16L30 9L16 2Z" stroke="url(#footerLogoGradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M2 9V23L16 30L30 23V9" stroke="url(#footerLogoGradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M16 16V30" stroke="url(#footerLogoGradient)" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M9 12.5L16 16L23 12.5" stroke="url(#footerLogoGradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <defs>
                <linearGradient id="footerLogoGradient" x1="2" y1="2" x2="30" y2="30" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#A078FF"/>
                  <stop offset="1" stop-color="#78FFD2"/>
                </linearGradient>
              </defs>
            </svg>
          </div>
          <div class="flex flex-col leading-tight">
            <span class="text-[1.35rem] font-bold tracking-[-0.02em] bg-gradient-to-br from-[#A078FF] to-[#78FFD2] bg-clip-text text-transparent">STUDIO</span>
            <span class="text-[0.65rem] font-medium text-white/45 tracking-[0.5px]">est. 2024</span>
          </div>
        </a>
        <p class="text-sm leading-relaxed text-white/65 max-w-[320px]">
          Crafting exceptional digital experiences with cutting-edge technology and creative design.
        </p>
      </div>

      <!-- Navigation Links -->
      <div class="flex gap-8 max-sm:gap-6">
        <div class="flex flex-col gap-4">
          <h4 class="text-[0.75rem] font-semibold uppercase tracking-[0.1em] text-white/50 mb-0">Explore</h4>
          <ul class="flex flex-col gap-2.5">
            <li><a href="/" class="text-sm text-white/60 no-underline transition-all duration-200 hover:text-[#A078FF] hover:translate-x-1 inline-block">Home</a></li>
            <li><a href="/projects" class="text-sm text-white/60 no-underline transition-all duration-200 hover:text-[#A078FF] hover:translate-x-1 inline-block">Projects</a></li>
            <li><a href="/journal" class="text-sm text-white/60 no-underline transition-all duration-200 hover:text-[#A078FF] hover:translate-x-1 inline-block">Journal</a></li>
            <li><a href="/about" class="text-sm text-white/60 no-underline transition-all duration-200 hover:text-[#A078FF] hover:translate-x-1 inline-block">About</a></li>
            <li><a href="/contact" class="text-sm text-white/60 no-underline transition-all duration-200 hover:text-[#A078FF] hover:translate-x-1 inline-block">Contact</a></li>
          </ul>
        </div>
      </div>

      <!-- Contact & Social -->
      <div class="flex flex-col gap-4">
        <h4 class="text-[0.75rem] font-semibold uppercase tracking-[0.1em] text-white/50 mb-0">Connect</h4>
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-2.5 text-sm text-white/60 transition-colors duration-200 hover:text-[#78FFD2]">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 8L10.5 13.5C11.2 14 12.8 14 13.5 13.5L21 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <span>hello@studio.com</span>
          </div>
          <div class="flex items-center gap-2.5 text-sm text-white/60 transition-colors duration-200 hover:text-[#78FFD2]">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="12" cy="9" r="3" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <span>San Francisco, CA</span>
          </div>
        </div>
        
        <!-- Colorful Social Links -->
        <div class="flex gap-3 flex-wrap mt-2">
          {socialLinks.map((social) => (
            <a 
              href={social.href} 
              target="_blank" 
              rel="noopener noreferrer"
              class="social-link-footer flex items-center justify-center w-[38px] h-[38px] bg-white/6 border border-white/10 rounded-full text-white/70 transition-all duration-250 no-underline hover:bg-[var(--social-color)] hover:border-[var(--social-color)] hover:text-white hover:-translate-y-1 hover:shadow-[0_4px_12px_rgba(0,0,0,0.2)]"
              style={`--social-color: ${social.color}`}
              aria-label={social.name}
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="transition-all duration-250 hover:stroke-white">
                {social.icon === 'instagram' && (
                  <path d="M17 2H7C4.23858 2 2 4.23858 2 7V17C2 19.7614 4.23858 22 7 22H17C19.7614 22 22 19.7614 22 17V7C22 4.23858 19.7614 2 17 2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                )}
                {social.icon === 'twitter' && (
                  <path d="M23 3C22.1 3.9 21 4.4 19.8 4.6C19.1 3.9 18.1 3.5 17 3.5C14.9 3.5 13.2 5.2 13.2 7.3C13.2 7.6 13.2 7.9 13.3 8.2C10.2 8 7.5 6.6 5.6 4.3C4.8 5.6 4.8 7.2 5.7 8.3C4.9 8.3 4.2 8.1 3.6 7.7C3.6 9.3 4.8 10.7 6.3 11C5.6 11.2 4.8 11.2 4.1 11C4.5 12.4 5.8 13.4 7.3 13.4C6.1 14.3 4.6 14.8 3 14.8C2.7 14.8 2.3 14.8 2 14.7C3.5 15.7 5.3 16.3 7.2 16.3C14 16.3 17.6 10.7 17.6 5.8C17.6 5.6 17.6 5.4 17.6 5.2C18.5 4.5 19.3 3.8 20 3H23Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                )}
                {social.icon === 'linkedin' && (
                  <>
                  <path d="M16 8C18.2091 8 20 9.79086 20 12V20H16V12C16 10.8954 15.1046 10 14 10C12.8954 10 12 10.8954 12 12V20H8V12C8 9.79086 9.79086 8 12 8C13.1046 8 14 8.89543 14 10C14 8.89543 14.8954 8 16 8Z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                  <rect x="4" y="8" width="4" height="12" stroke="currentColor" stroke-width="1.5" fill="none"/>
                  <circle cx="6" cy="4" r="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
                  </>
                )}
                {social.icon === 'github' && (
                  <path d="M9 19C4 20.5 4 16.5 2 16M15 22V18.5C15.1 17.5 15 16.5 15.5 15.5C17.5 15.5 19.5 16.5 19.5 14C19.5 13.5 19.3 12.5 18.5 12C19.3 11 19.5 10 19 9C18 9 17.5 9.5 16.5 10C15 9.5 13 9.5 11.5 10C10.5 9.5 10 9 9 9C8.5 10 8.7 11 9.5 12C8.7 12.5 8.5 13.5 8.5 14C8.5 16.5 10.5 15.5 12.5 15.5C13 16.5 12.9 17.5 13 18.5V22" stroke="currentColor" stroke-width="1.5" fill="none"/>
                )}
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Footer Bottom Bar -->
    <div class="flex justify-between items-center pt-6 border-t border-white/8 flex-wrap gap-4 max-sm:flex-col max-sm:text-center">
      <p class="text-[0.75rem] text-white/40">&copy; {year} STUDIO. All rights reserved.</p>
      <button id="backToTop" class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-4 py-2 text-[0.75rem] font-medium text-white/60 cursor-pointer transition-all duration-200 hover:bg-[rgba(160,120,255,0.15)] hover:border-[rgba(160,120,255,0.4)] hover:text-[#A078FF] hover:-translate-y-0.5" aria-label="Back to top">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 19V5M12 5L5 12M12 5L19 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Back to top</span>
      </button>
    </div>
    
  </div>
</footer>

<style is:global>
  /* ============================================
     SOCIAL LINK HOVER - Preserved from original
     ============================================ */
  
  .social-link-footer:hover svg {
    stroke: #FFFFFF;
  }
</style>

<script>
  // Back to top functionality
  const backToTopBtn = document.getElementById('backToTop');
  
  if (backToTopBtn) {
    backToTopBtn.addEventListener('click', () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });
  }
</script>